{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.10.0",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build && npm run perf:check",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:a11y": "vitest run src/app/accessibility.routes.test.tsx",
    "e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --workers=1 --retries=2 --reporter=line",
    "perf:check": "node ./scripts/performance-budget.mjs",
    "deps:audit": "node ./scripts/dependency-audit.mjs",
    "openapi:sync": "node ./scripts/sync-openapi.mjs",
    "openapi:check": "node ./scripts/sync-openapi.mjs --check",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run openapi:check && npm run deps:audit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^27.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.1.12",
    "vitest": "^4.0.8"
  }
}
