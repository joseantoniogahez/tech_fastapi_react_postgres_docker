# Template for Docker Compose local configuration.
# Copy this file to .env and customize values for your machine.

# ------------------------------------------------------------
# API SERVICE (FastAPI container + runtime behavior)
# ------------------------------------------------------------
# API_HOST: backend container name/hostname used inside the Docker network.
API_HOST=library-api

# APP_ENV: backend runtime environment (local, test, prod).
# In prod, JWT_* variables become required and validated strictly.
APP_ENV=local

# API_PORT: backend port exposed on host and used by the backend container.
API_PORT=8000

# API_PATH: FastAPI root_path metadata (useful behind a reverse proxy).
# Canonical local contract mounts API routes at root, so keep this empty.
API_PATH=

# API_CORS_ORIGINS: comma-separated list of browser origins allowed by CORS.
API_CORS_ORIGINS=http://localhost:3000

# LOG_LEVEL: backend logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=WARNING

# ------------------------------------------------------------
# AUTH SERVICE (JWT signing and expiration)
# ------------------------------------------------------------
# JWT_SECRET_KEY: JWT signing secret.
# Local/test can use this default. In prod set a strong random secret.
JWT_SECRET_KEY=local-dev-jwt-secret  # pragma: allowlist secret

# JWT_ALGORITHM: JWT algorithm.
JWT_ALGORITHM=HS256

# JWT_ACCESS_TOKEN_EXPIRE_MINUTES: access token lifetime in minutes.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# DATABASE SERVICE (PostgreSQL connection for backend)
# ------------------------------------------------------------
# DB_HOST: database container hostname in the Docker network.
DB_HOST=library_db

# DB_PORT: PostgreSQL port exposed on host.
DB_PORT=5432

# DB_NAME: PostgreSQL database name.
DB_NAME=library

# DB_USER: PostgreSQL username.
DB_USER=my_admin

# DB_PASSWORD: PostgreSQL password (change before first run).
DB_PASSWORD=REPLACE_ME  # pragma: allowlist secret

# DB_TYPE: SQLAlchemy async driver for PostgreSQL.
DB_TYPE=postgresql+asyncpg

# ------------------------------------------------------------
# FRONTEND SERVICE (Next.js container network/port settings)
# ------------------------------------------------------------
# UI_HOST: frontend container name/hostname used in Docker network.
UI_HOST=next

# UI_PORT: frontend port exposed on host.
UI_PORT=3000

# NEXT_PUBLIC_API_ORIGIN: API origin consumed by browser-side frontend code.
# If API_PORT changes, update this value accordingly.
NEXT_PUBLIC_API_ORIGIN=http://localhost:8000

# NEXT_PUBLIC_API_BASE_PATH: API base path consumed by browser-side frontend code.
# Canonical contract uses root-mounted API routes.
NEXT_PUBLIC_API_BASE_PATH=/

# UI_PATH: reserved for proxy/path-based deployments (not consumed directly here).
UI_PATH=/

# ------------------------------------------------------------
# BUILD AND CONTAINER LOGGING (optional tuning)
# ------------------------------------------------------------
# PYTHON_VERSION: Python version used to build the backend image.
PYTHON_VERSION=3.14.3

# BACKEND_LOG_MAX_SIZE: max size per backend container log file.
BACKEND_LOG_MAX_SIZE=10m

# BACKEND_LOG_MAX_FILE: max number of rotated backend log files.
BACKEND_LOG_MAX_FILE=3
